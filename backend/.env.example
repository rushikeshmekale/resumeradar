# MongoDB Atlas connection string
# Get this from Atlas -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/resumeradar?retryWrites=true&w=majority

# Any long random string (used to sign login tokens)
JWT_SECRET=replace_with_a_long_random_string

# How long a login session lasts
JWT_EXPIRES_IN=7d

# Google Gemini API key (free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed frontend origins (your Vercel URL + localhost)
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app

PORT=4000
NODE_ENV=development
